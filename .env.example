COINEX_ACCESS_ID=your_access_id
COINEX_SECRET_KEY=your_secret_key
# Alternative for safer server deploys:
# COINEX_ACCESS_ID_FILE=/run/secrets/coinex_access_id
# COINEX_SECRET_KEY_FILE=/run/secrets/coinex_secret_key

# Safety first: keep this true until you have tested on a tiny size.
DRY_RUN=true

# Trading defaults
COINEX_MARKET_TYPE=FUTURES
COINEX_MARGIN_MODE=isolated
COINEX_LEVERAGE=20
COINEX_TRIGGER_PRICE_TYPE=latest_price

# Position sizing:
# Either set POSITION_SIZE_BASE directly, or use MARGIN_USDT and the bot will
# compute size as (margin_usdt * leverage) / entry_price.
# Or set DEFAULT_BALANCE_PCT to use a percentage of available futures balance.
POSITION_SIZE_BASE=
MARGIN_USDT=10
DEFAULT_BALANCE_PCT=
FUTURES_QUOTE_CCY=USDT

# Entry execution mode:
# limit = place at signal entry
# market = enter immediately
ENTRY_ORDER_TYPE=limit

# Break-even logic:
# tp1_fill = move SL after the first TP is confirmed by position/deal updates
# price_touch = move SL as soon as public WS shows TP1 touched
BREAK_EVEN_MODE=tp1_fill

# Optional override; if empty the bot uses the parsed entry price.
BREAK_EVEN_PRICE_OVERRIDE=

# Runtime files
STATE_FILE=runtime\\active_trade.json
LOG_LEVEL=INFO

# Dashboard protection for the online panel.
BOT_DASHBOARD_USERNAME=admin
BOT_DASHBOARD_PASSWORD=change_me_now

# Test trade safety.
TEST_TRADE_ENABLED=false
TEST_MARKET=BTCUSDT
TEST_HOLD_SECONDS=2
TEST_POSITION_SIZE_BASE=0.001
TEST_MARGIN_USDT=5

# Telegram auto-trading feed listener
TELEGRAM_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
# Comma-separated usernames or numeric chat/channel ids
TELEGRAM_SOURCE_CHATS=
# Optional overrides for Telegram-originated trades; leave empty to reuse the main defaults
TELEGRAM_BALANCE_PCT=
TELEGRAM_LEVERAGE=

# Paper-trading Telegram channels: parsed and monitored, but no real CoinEx orders are sent.
TELEGRAM_PAPER_SOURCE_CHATS=
TELEGRAM_PAPER_BALANCE_PCT=
TELEGRAM_PAPER_LEVERAGE=
